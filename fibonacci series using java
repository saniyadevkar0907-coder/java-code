public class fibonacci {
    public static void main(String[] args) {
        // Initialize first two fibonacci numbers
        int a=0;
        int b=1;
        //print first nimber
        System.out.print(a);
        // loop to print the next 10 finonacci numbers
        for(int i=0;i<=10;i++){
            //calculate next fibonacci number
            int temp=a+b;
            //update the values
            a=b;
            b=temp;
            //print the fibonacci numbers
            System.out.print(a);
        }
        }
    }
    
